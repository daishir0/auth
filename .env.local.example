# JWT Secret Key (MUST change in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Encryption Secret for sensitive settings (e.g., Google SSO Client Secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET="your-encryption-secret-change-in-production"

# Database URL
DATABASE_URL="file:./db/auth.db"

# ========================================
# 認可サーバー設定 (必須)
# ========================================
# 認可サーバーの公開URL（トークンの発行者として使用）
AUTH_URL="https://your-auth-domain.com"
OAUTH_ISSUER="https://your-auth-domain.com"

# リダイレクト許可ホスト（カンマ区切り）
# オープンリダイレクト脆弱性対策のためのホワイトリスト
# NEXT_PUBLIC_ はクライアントサイド（AuthForm.tsx）で使用
NEXT_PUBLIC_ALLOWED_REDIRECT_HOSTS="localhost:3018,localhost:3019,your-auth-domain.com,your-app-domain.com"

# ========================================
# シード設定（開発/テスト用）
# ========================================
SEED_ADMIN_EMAIL="admin@example.com"
SEED_USER_EMAIL="user@example.com"
# OAuthクライアントのリダイレクトURI（カンマ区切り）
SEED_OAUTH_REDIRECT_URIS="https://your-app-domain.com/api/auth/callback/auth-provider,http://localhost:3018/api/auth/callback/auth-provider"
